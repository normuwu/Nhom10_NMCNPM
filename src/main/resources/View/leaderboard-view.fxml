<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="coganhgame.Controller.LeaderboardController"
            prefHeight="550.0" prefWidth="800.0" style="-fx-background-color: #F5F5F5;">
    <top>
        <VBox alignment="CENTER" spacing="10.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/></padding>
            <Label text="Match History &amp; Leaderboard">
                <font><Font name="Cambria Bold" size="30.0"/></font>
            </Label>
            <Label fx:id="lblStats" style="-fx-text-fill: #555;" text="No matches played yet.">
                <font><Font name="Calibri" size="16.0"/></font>
            </Label>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <padding><Insets bottom="5.0" left="15.0" right="15.0" top="5.0"/></padding>
            <TableView fx:id="historyTable" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colPlayer1" text="Player 1" prefWidth="130"/>
                    <TableColumn fx:id="colPlayer2" text="Player 2" prefWidth="130"/>
                    <TableColumn fx:id="colWinner" text="Winner" prefWidth="130"/>
                    <TableColumn fx:id="colMode" text="Mode" prefWidth="120"/>
                    <TableColumn fx:id="colDuration" text="Duration" prefWidth="100"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="15.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="10.0"/></padding>
            <Button onAction="#onClearClick" style="-fx-background-color: #E74646; -fx-text-fill: white;" text="Clear History">
                <cursor><Cursor fx:constant="HAND"/></cursor>
            </Button>
            <Button onAction="#onCloseClick" style="-fx-background-color: #4d8e2f; -fx-text-fill: white;" text="Close">
                <cursor><Cursor fx:constant="HAND"/></cursor>
            </Button>
        </HBox>
    </bottom>
</BorderPane>